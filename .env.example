# =============================================================================
# Carbon Footprint Awareness Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---- Google Cloud Project ---------------------------------------------------
PROJECT_ID=your-gcp-project-id
REGION=us-central1

# ---- Frontend ---------------------------------------------------------------
# Optional for static hosting. Leave blank when frontend and API share one origin.
VITE_API_BASE_URL=

# ---- Feature Flags ----------------------------------------------------------
# Set to false for local development without GCP credentials.
# All services have safe in-memory fallbacks when disabled.
USE_GEMINI=true
USE_FIRESTORE=true
USE_BIGQUERY=true
USE_PUBSUB=true

# ---- BigQuery ---------------------------------------------------------------
BIGQUERY_DATASET=carbon_analytics
BIGQUERY_TABLE=carbon_events

# ---- Pub/Sub ----------------------------------------------------------------
PUBSUB_TOPIC=carbon-insights

# ---- Gemini Model -----------------------------------------------------------
GEMINI_MODEL=gemini-1.5-flash

# ---- Application ------------------------------------------------------------
ENVIRONMENT=production
LOG_LEVEL=INFO
MAX_HISTORY_ENTRIES=20
